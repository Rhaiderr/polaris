# ============================================================================
# Polaris — classification categories (GENERIC EXAMPLE)
# This file is seeded to /config/polaris/<email>/categorias.yaml when an
# account is linked. Edit it with YOUR OWN Gmail labels (plain text file).
#
# The classifier builds the category list dynamically from here — changing
# categories requires NO code changes. 'descricao' guides the model.
# NOTE: the sample data below is in Portuguese because the LLM prompt
# currently is too (see classificador.py). Categories in any language work.
# ============================================================================

# Internal Polaris labels (not classification categories).
# Polaris creates these labels in Gmail if they do not exist.
labels_internas:
  processado: "Polaris/Processado"          # idempotency marker
  lixeira_candidata: "Polaris/Lixeira-candidata"  # shadow mode for trashing

# Fallback category when the JSON is invalid or confidence is low.
# MUST exist and NEVER allows automatic trashing/archiving.
categoria_revisar: "Revisar"

categorias:
  - nome: "Promoções"
    descricao: "Newsletters, marketing, ofertas, cupons, propaganda. Email de massa/promocional."
    permitir_exclusao: true      # the only category eligible for trashing (adjust to taste)

  - nome: "Recibos"
    descricao: "Comprovantes, notas fiscais, faturas pagas, confirmações de pagamento."
    permitir_exclusao: false

  - nome: "Segurança"
    descricao: "Códigos OTP, alertas de login, avisos de segurança. SENSÍVEL — nunca excluir."
    permitir_exclusao: false
    arquivar_permitido: false     # (optional, default true) never auto-leaves the inbox; label only

  # Examples of personal categories — replace with your real labels:
  - nome: "Trabalho"
    descricao: "Assuntos profissionais, colegas, projetos do trabalho."
    permitir_exclusao: false

  - nome: "Finanças"
    descricao: "Banco, cartão, investimentos, faturas."
    permitir_exclusao: false
