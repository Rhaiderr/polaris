# ============================================================================
# Polaris — configuração de ambiente (copie para .env e ajuste)
#   cp .env.example .env
# O .env NÃO é versionado (ver .gitignore).
# ============================================================================

# --- Endpoint do modelo (qualquer API OpenAI-compatible) --------------------
# Funciona com LM Studio, Ollama, llama.cpp, vLLM, OpenRouter, OpenAI, etc.
# O caminho /v1 é o prefixo padrão OpenAI; o código chama /v1/chat/completions.
#
#   • Modelo em OUTRA máquina na LAN (ex.: um PC servindo o modelo):
#       LLM_BASE_URL=http://192.168.0.50:1234/v1
#
#   • Modelo na MESMA máquina que roda o container Docker:
#       use host.docker.internal (o compose já mapeia via extra_hosts):
#       LLM_BASE_URL=http://host.docker.internal:1234/v1
#     ('localhost' dentro do container NÃO alcança o host — não use.)
#
#   • Rodando fora do Docker (dry-run local) com o modelo no mesmo host:
#       LLM_BASE_URL=http://localhost:1234/v1
LLM_BASE_URL=http://host.docker.internal:1234/v1

# Nome do modelo, exatamente como o endpoint o expõe.
LLM_MODEL=seu-modelo-aqui

# Chave da API. Vazio para endpoints locais; preencha para APIs pagas.
LLM_API_KEY=

# --- Parâmetros do modelo (defaults sensatos) -------------------------------
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=400
LLM_TIMEOUT=120

# --- Comportamento do Polaris -----------------------------------------------
# Modo sombra: em vez de mandar para a Lixeira, apenas aplica a label
# 'Polaris/Lixeira-candidata'. Mantenha 'true' por semanas até auditar os logs.
MODO_SOMBRA_EXCLUSAO=true

# Exclusão permanente NUNCA — sempre vai para a Lixeira (recuperável ~30 dias).
# Deixe 'false'. (Reservado; o código ignora exclusão permanente por segurança.)
EXCLUSAO_PERMANENTE=false

# Retenção do log de auditoria (decisoes.jsonl contém emails originais).
LOG_RETENCAO_DIAS=90
