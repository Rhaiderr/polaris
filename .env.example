# ============================================================================
# Polaris — environment configuration (copy to .env and adjust)
#   cp .env.example .env
# The .env file is NOT versioned (see .gitignore).
# ============================================================================

# --- Model endpoint (any OpenAI-compatible API) -----------------------------
# Works with LM Studio, Ollama, llama.cpp, vLLM, OpenRouter, OpenAI, etc.
# The /v1 suffix is the standard OpenAI prefix; the code calls /v1/chat/completions.
#
#   • Model on ANOTHER machine on the LAN (e.g. a PC serving the model):
#       LLM_BASE_URL=http://192.168.0.50:1234/v1
#
#   • Model on the SAME machine that runs the Docker container:
#       use host.docker.internal (compose already maps it via extra_hosts):
#       LLM_BASE_URL=http://host.docker.internal:1234/v1
#     ('localhost' inside the container does NOT reach the host — don't use it.)
#
#   • Running outside Docker (local dry-run) with the model on the same host:
#       LLM_BASE_URL=http://localhost:1234/v1
LLM_BASE_URL=http://host.docker.internal:1234/v1

# Model name, exactly as the endpoint exposes it.
LLM_MODEL=your-model-here

# API key. Empty for local endpoints; fill in for paid APIs.
LLM_API_KEY=

# --- Model parameters (sensible defaults) -----------------------------------
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=400
LLM_TIMEOUT=120

# --- Polaris behavior -------------------------------------------------------
# Shadow mode: instead of sending to the Trash, only applies the
# 'Polaris/Lixeira-candidata' label. Keep 'true' for weeks until you have
# audited the logs.
MODO_SOMBRA_EXCLUSAO=true

# Permanent deletion is NEVER done — everything goes to the Trash (recoverable
# ~30 days). Leave 'false'. (Reserved; the code ignores permanent deletion for
# safety.)
EXCLUSAO_PERMANENTE=false

# Audit-log retention (decisoes.jsonl contains the original emails).
LOG_RETENCAO_DIAS=90
