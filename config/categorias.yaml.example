# ============================================================================
# Polaris — classification categories (GENERIC EXAMPLE — versioned)
#   cp config/categorias.yaml.example config/categorias.yaml
# then adjust the categories to match YOUR Gmail labels. The real file
# (config/categorias.yaml) is gitignored (label names are personal data).
#
# The classifier builds the category list dynamically from here — changing
# categories does NOT require touching Python. 'descricao' guides the model.
# ============================================================================

# Polaris internal labels (not classification categories).
# Polaris creates these labels in Gmail if they don't exist.
labels_internas:
  processado: "Polaris/Processado"                # idempotency marker
  lixeira_candidata: "Polaris/Lixeira-candidata"  # shadow-mode trash candidate

# Fallback category when the JSON is invalid or confidence is low.
# It MUST exist and NEVER allows automatic trashing/archiving.
categoria_revisar: "Revisar"

categorias:
  - nome: "Promotions"
    descricao: "Newsletters, marketing, offers, coupons, ads. Bulk/promotional email."
    permitir_exclusao: true      # the only category eligible for trashing (tune to taste)

  - nome: "Receipts"
    descricao: "Proofs of purchase, invoices, paid bills, payment confirmations."
    permitir_exclusao: false

  - nome: "Security"
    descricao: "OTP codes, login alerts, security warnings. SENSITIVE — never trash."
    permitir_exclusao: false
    arquivar_permitido: false     # (optional, default true) never leaves the inbox automatically; only gets a label

  # Examples of personal categories — replace with your real labels:
  - nome: "Work"
    descricao: "Professional matters, colleagues, work projects."
    permitir_exclusao: false

  - nome: "Finance"
    descricao: "Bank, credit card, investments, bills."
    permitir_exclusao: false
